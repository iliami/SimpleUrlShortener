{
  "ThisService": {
    "Name": "AnalyticsCollector",
    "Version": "1.0.0"
  },
  "Serilog": {
    "Using":  [ "Serilog.Sinks.Console" ],
    "MinimumLevel": "Debug",
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "SimpleUrlShortener"
    }
  },
  "ConnectionStrings": {
    "Postgres" : "Host=vnopn; Port=5432; Database=SimpleUrlShortener; Username=root; Password=password; Pooling=true; Minimum Pool Size=0; Maximum Pool Size=100;",
  },
  "RabbitMqConnectionSettings": {
    "Host": "vnopn",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "root",
    "Password": "password",
    "ConnectionRetryCount": 3,
    "ConnectionRetryIntervalMs": 1000
  },
  "RabbitMqEventBusConsumerSettings": {
    "RequeueDelayMs": 1000,
    "AutoAck": false,
    "PrefetchCount": 10
  },
  "AllowedHosts": "*"
}
