{
  "Serilog": {
    "Using":  [ "Serilog.Sinks.Console" ],
    "MinimumLevel": "Warning",
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "SimpleUrlShortener"
    }
  },
  "ConnectionStrings": {
    "Postgres" : "Host=vnopn; Port=5432; Database=SimpleUrlShortener; Username=root; Password=password; Pooling=true; Minimum Pool Size=0; Maximum Pool Size=100;"
  },
  "RabbitMqConnectionSettings": {
    "Host": "vnopn",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "root",
    "Password": "password",
    "ConnectionRetryCount": 3,
    "ConnectionRetryIntervalMs": 1000
  },
  "RabbitMqEventBusProducerSettings": {
    "PublishRetryCount": 5,
    "PublishRetryIntervalMs": 300,
    "PublishConfirmTimeoutMs": 5000,
    "UsePublisherConfirms": true,
    "UsePersistentMessages": true
  },
  "UrlShortenerSettings": {
    "MaxAttemptsToResolveCollision": 100,
    "InstancePrefix": "a"
  },
  "AllowedHosts": "*"
}
